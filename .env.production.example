# Variables de entorno para producción
# Copia este archivo a .env.production en tu servidor EC2
# NO COMITEAR ESTE ARCHIVO CON VALORES REALES

# ========================================
# CONFIGURACIÓN DE NEXT.JS
# ========================================
NODE_ENV=production
PORT=3000

# ========================================
# SUPABASE - PRODUCCIÓN
# ========================================
# URL de tu proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Anon key (pública - puede estar en el frontend)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (SECRETA - solo para server-side)
# ⚠️ NUNCA expongas esta clave en el cliente
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ========================================
# URL DEL SITIO
# ========================================
# URL pública de tu sitio (para redirects, emails, etc)
NEXT_PUBLIC_SITE_URL=https://tu-dominio.com

# ========================================
# CONFIGURACIÓN DE SESIÓN
# ========================================
# Secret para firmar cookies de sesión (genera uno único)
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET=tu-secret-key-muy-seguro-aqui

# ========================================
# CONFIGURACIÓN DE EMAILS (Opcional)
# ========================================
# Si usas servicios de email como SendGrid, Resend, etc.
# EMAIL_FROM=noreply@entrysport.com
# EMAIL_SERVER_HOST=smtp.sendgrid.net
# EMAIL_SERVER_PORT=587
# EMAIL_SERVER_USER=apikey
# EMAIL_SERVER_PASSWORD=tu-api-key

# ========================================
# ANALYTICS (Opcional)
# ========================================
# Google Analytics 4 - Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-8VRJM61V17

# ========================================
# PAGOS (Opcional - para futuro)
# ========================================
# Culqi, Mercado Pago, etc.
# NEXT_PUBLIC_CULQI_PUBLIC_KEY=pk_test_...
# CULQI_SECRET_KEY=sk_test_...

# ========================================
# CONFIGURACIÓN DE LOGS
# ========================================
# Nivel de logs (error, warn, info, debug)
LOG_LEVEL=info

# ========================================
# OTRAS CONFIGURACIONES
# ========================================
# Deshabilitar telemetría de Next.js
NEXT_TELEMETRY_DISABLED=1
